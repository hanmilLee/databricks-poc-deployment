env_name                       = "databricks"
user_name                      = "[firstname.lastname]"                                        # example. "hanmil.lee"
region                         = "ap-northeast-2"                                              # 사용될 region
prefix                         = "mycompany001-poc"                                            # 사용될 databricks workspace name
deployment_name_prefix_enabled = false                                                         # Salesforce상에서 prefix 가 enable 된 경우 true, 아니면 false
deployment_name                = null                                                          # deployment_name_prefix_enabled = true인 경우, workspace url 앞부분에 들어갈 prefix 입력
databricks_account_id          = "[databricks account id]"                                     # "xxxxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
client_id                      = "[service principal client id]"                               # "56xxxxxx-xxxx-xxxx-xxxx-xxxxxxxxxxxx"
client_secret                  = "[service principal client secret]"                           # "dosxxxxxxxxxxxxxxxxxxxxxxxxx"
cidr_block                     = "[vpc cidr block]"                                            # example. "10.10.0.0/16" (서브넷이 /26 이상 되도록 /23 이상 권장)
# availability_zones           = null                                                          # null=엔드포인트 지원 AZ 교집합 자동 선택. 특정 AZ 강제 시 ["ap-northeast-2a","ap-northeast-2c"]
metastore_id                   = "[metastore id]"                                              # 리전에 이미 metastore 있으면 그 ID 입력, 없으면 빈 문자열("")로 두면 신규 생성됨 (리전당 1개 제약)
enable_unity_catalog           = true                                                          # Unity Catalog 리소스 생성 여부
enable_backend_private_link    = false                                                         # true면 Backend Private Link (REST + SCC Relay) 생성. Databricks Enterprise tier 필요
enable_nat_gateway             = true                                                          # true=Option 1(NAT+IGW+public subnet). false=Option 2(완전 사설, Backend PL+UC-only 자동)
